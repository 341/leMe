# Production URL — required for SEO (canonical, Open Graph, sitemap)
NEXT_PUBLIC_SITE_URL=https://erollmaxhuni.com

# Optional: Google Search Console verification
# GOOGLE_SITE_VERIFICATION=

# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-T52WE3ZVWN

# Web Bot Auth — Ed25519 private JWK (JSON, single line). Generate with:
# openssl genpkey -algorithm ed25519 -out private.pem && node -e "console.log(JSON.stringify(require('crypto').createPrivateKey(require('fs').readFileSync('private.pem')).export({format:'jwk'})))"
# WEB_BOT_AUTH_PRIVATE_JWK={"kty":"OKP","crv":"Ed25519","d":"...","x":"..."}

# Bot paywall — set a strong secret in production
# PAYMENT_ACCESS_SECRET=replace-with-long-random-string
# PAYMENT_ENABLED=true
# PAYMENT_MODE=soft
# Set PAYMENT_MODE=hard to block bots with HTTP 402 until payment is verified
# PAYMENT_BASE_USD=0.05
# PAYMENT_SESSION_HOURS=24
# PAYMENT_CHALLENGE_MINUTES=60
# Optional chain indexer API keys: HELIUS_API_KEY, TRONGRID_API_KEY, ETHERSCAN_API_KEY
